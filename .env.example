# === Gamma API ===
GAMMA_API_KEY=your_gamma_api_key
MOCK_MODE=false

# === Webhook security ===
TILDA_SECRET=optional_secret_token_for_webhook_security
ALLOWED_ORIGINS=https://your-site.tilda.ws,https://yourdomain.ru

# === NotiSend (transactional email) ===
NOTISEND_API_KEY=your_notisend_api_key
NOTISEND_FROM_EMAIL=noreply@presentaciya.ru
NOTISEND_FROM_NAME=presentaciya.ru

# === Timeweb S3 (file storage) ===
S3_ENDPOINT=https://s3.timeweb.cloud
S3_BUCKET=your_bucket_name
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_REGION=ru-1

# === Backend public URL (used in download links sent by email) ===
BACKEND_URL=https://api.presentaciya.ru
